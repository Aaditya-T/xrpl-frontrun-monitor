XRPLDATA_API_KEY=your_stream_api_key_here

# Paid live stream from https://stream-docs.xrpldata.com/
XRPLDATA_STREAM_URL=wss://stream.xrpldata.com

# Free REST API from https://xrpldata.inftf.org/docs
XRPLDATA_REST_URL=https://xrpldata.inftf.org/v1

# Optional enrichment for Sequence/TicketSequence and raw tx details.
# Turn this on for targeted streams/backfills; broad all/all streams can produce too many tx lookups.
XRPL_ENRICH_TX=false
XRPL_RPC_URL=https://s1.ripple.com:51234/

# Stream filters. Use all/all for broad capture, or set a pair.
XRPL_BASE=all
XRPL_QUOTE=all
XRPL_EXCHANGE=dex
XRPL_STREAM_TYPE=all

# Detection thresholds.
DETECTOR_MIN_PROFIT_BPS=3
DETECTOR_MAX_LEDGER_GAP=1
DETECTOR_MAX_TX_GAP=40
DETECTOR_MIN_VICTIM_VOLUME_RATIO=0.25
DETECTOR_HISTORY_SIZE=2500
